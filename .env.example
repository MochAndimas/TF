# Traders Family Dashboard environment template.
# Copy this file to .env and replace every "change-me" placeholder.
# Never commit real secrets or provider credentials.

# Core runtime
ENV=development
DEV_HOST=localhost
DEV_PORT=8000
HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=5504
WORKERS=1

# SQLite database
DEV_DB_URL=sqlite+aiosqlite:///./app/db/campaign_data_dev.db
DB_URL=sqlite+aiosqlite:///./app/db/campaign_data.db
SQLITE_BUSY_TIMEOUT_MS=30000
AUTO_INIT_DB_ON_STARTUP=false
ALLOW_CONCURRENT_ETL_RUNS=false

# Public/internal URLs
FRONTEND_URL=http://localhost:5504,http://127.0.0.1:5504,http://localhost:8501,http://127.0.0.1:8501
BACKEND_PUBLIC_URL=http://localhost:5505
STREAMLIT_API_HOST=http://localhost:5505
INTERNAL_TRUSTED_HOSTS=

# Auth and security secrets
CSRF_SECRET=change-me
JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me
APP_ENCRYPTION_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Optional bootstrap superadmin
BOOTSTRAP_SUPERADMIN=false
INITIAL_SUPERADMIN_NAME=admin
INITIAL_SUPERADMIN_EMAIL=admin@example.com
INITIAL_SUPERADMIN_PASSWORD=change-me

# Request logging
REQUEST_LOG_ENABLED=true
REQUEST_LOG_SAMPLE_RATE=1.0
REQUEST_LOG_RETENTION_DAYS=30
REQUEST_LOG_RETENTION_CLEANUP_SAMPLE_RATE=0.01
REQUEST_LOG_QUEUE_MAX_SIZE=1000
REQUEST_LOG_FLUSH_BATCH_SIZE=50
REQUEST_LOG_FLUSH_INTERVAL_SECONDS=1.0

# Analytics dataframe cache
ANALYTICS_DATAFRAME_CACHE_ENABLED=true
ANALYTICS_DATAFRAME_CACHE_TTL_SECONDS=300
ANALYTICS_DATAFRAME_CACHE_MAX_ENTRIES=64

# Google Sheets / Google Ads / GA4
GSHEET_SA_CREDS=change-me
GSHEET_SHEET_ID=change-me
FIRST_DEPOSIT_SHEET_ID=change-me
FIRST_DEPOSIT_SHEET_RANGE=change-me
DAILY_REGIS_SHEET_ID=change-me
DAILY_REGIS_SHEET_RANGE=change-me
GA4_PROPERTY_ID=change-me
GA4_SA_CREDS=change-me
GOOGLE_ADS_DEVELOPER_TOKEN=change-me
GOOGLE_ADS_CLIENT_ID=change-me
GOOGLE_ADS_CLIENT_SECRET=change-me
GOOGLE_ADS_LOGIN_CUSTOMER_ID=change-me
GOOGLE_ADS_CUSTOMER_ID=change-me
GOOGLE_ADS_REDIRECT_URI=http://localhost:8000/api/google-ads/oauth/callback

# Meta / Instagram
META_APP_ID=change-me
META_APP_SECRET=change-me
META_API_VERSION=v23.0
INSTAGRAM_ACCOUNT_ID=change-me

# YouTube
YOUTUBE_CLIENT_ID=change-me
YOUTUBE_CLIENT_SECRET=change-me
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback
YOUTUBE_CHANNEL_ID=change-me
YOUTUBE_MEDIA_INSIGHT_CONCURRENCY=3

# TikTok
TIKTOK_CLIENT_KEY=change-me
TIKTOK_CLIENT_SECRET=change-me
TIKTOK_REDIRECT_URI=http://localhost:5505/api/tiktok/oauth/callback
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list
